# Treat all HTML, CSS, and JS files as vendored (ignored from language stats)
*.html linguist-vendored
*.css linguist-vendored
*.js linguist-vendored
*.json linguist-vendored

# Force code generator and UI files to be ignored or treated as C++
*.ui linguist-vendored
*.xml linguist-vendored

# Ensure C++ takes absolute priority
*.cpp linguist-language=C++
*.h linguist-language=C++
*.hpp linguist-language=C++
